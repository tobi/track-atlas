{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tobi/track-atlas/schema/track.schema.json",
  "title": "Track",
  "description": "Clean, source-agnostic metadata for a single racing circuit (tracks/<slug>/track.json). GENERATED from scripts/lib/models.py — do not edit by hand; run scripts/build_schema.py.",
  "$defs": {
    "Corner": {
      "additionalProperties": false,
      "properties": {
        "number": {
          "description": "Sequential corner number 1..N, no gaps — the ordering key.",
          "title": "Number",
          "type": "integer"
        },
        "code": {
          "description": "Trackside identifier (usually str(number); '5a'/'5b' for split apexes). The 'numbered' layer is this as 'Turn <code>'.",
          "title": "Code",
          "type": "string"
        },
        "names": {
          "description": "Name layers keyed by layer code (see track.name_layers). 'numbered' is always present; other layers appear only when a name is known. An unnamed corner carries only 'numbered'.",
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": {
              "type": "string"
            }
          },
          "title": "Names",
          "type": "object"
        },
        "complex": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Multi-corner complex this turn belongs to (e.g. 'Porsche Curves'). Corners sharing a complex must form one gap-free consecutive run.",
          "title": "Complex"
        },
        "direction": {
          "anyOf": [
            {
              "enum": [
                "left",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direction"
        },
        "scale": {
          "anyOf": [
            {
              "maximum": 6,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Severity 1-6: 1=Hairpin, 2=Slow, 3=Medium, 4=Fast, 5=Very fast, 6=Kink.",
          "title": "Scale"
        },
        "marker": {
          "anyOf": [
            {
              "description": "Lap fraction in [0,1].",
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Lap fraction at the apex.",
          "title": "Marker"
        },
        "start": {
          "anyOf": [
            {
              "description": "Lap fraction in [0,1].",
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Lap fraction where the corner begins.",
          "title": "Start"
        },
        "end": {
          "anyOf": [
            {
              "description": "Lap fraction in [0,1].",
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Lap fraction where the corner ends.",
          "title": "End"
        },
        "location": {
          "anyOf": [
            {
              "description": "[longitude, latitude] in GeoJSON axis order (WGS84).",
              "items": {
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Apex coordinate, when resolvable.",
          "title": "Location"
        },
        "location_source": {
          "anyOf": [
            {
              "enum": [
                "osm-way",
                "centerline",
                "manual"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location Source"
        }
      },
      "required": [
        "number",
        "code",
        "names"
      ],
      "title": "Corner",
      "type": "object"
    },
    "Geometry": {
      "additionalProperties": false,
      "properties": {
        "outline": {
          "description": "Path (relative to track dir) to the layout's GeoJSON.",
          "title": "Outline",
          "type": "string"
        },
        "crs": {
          "default": "EPSG:4326",
          "title": "Crs",
          "type": "string"
        }
      },
      "required": [
        "outline"
      ],
      "title": "Geometry",
      "type": "object"
    },
    "Layout": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "aka": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Aka",
          "type": "array"
        },
        "series": {
          "default": [],
          "description": "Series that use THIS layout, when it is series-specific (e.g. ['imsa'] vs ['wec'] for Sebring's two pit configurations). Empty = the track-level series all use this layout.",
          "items": {
            "type": "string"
          },
          "title": "Series",
          "type": "array"
        },
        "length_m": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Lap length in metres.",
          "title": "Length M"
        },
        "direction": {
          "anyOf": [
            {
              "enum": [
                "clockwise",
                "anticlockwise"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direction"
        },
        "active_years": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Free-form, e.g. '2018-' or '1972,1979-1989'.",
          "title": "Active Years"
        },
        "geometry": {
          "$ref": "#/$defs/Geometry"
        },
        "start_finish": {
          "anyOf": [
            {
              "$ref": "#/$defs/PointRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "name_default": {
          "default": "driver",
          "description": "Layer code (a key in track.name_layers) used as the default display name. Resolution is two steps: corner.names[name_default] if present, else corner.names.numbered — it does NOT fall through to other named layers.",
          "title": "Name Default",
          "type": "string"
        },
        "corners": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Corner"
          },
          "title": "Corners",
          "type": "array"
        },
        "straights": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Straight"
          },
          "title": "Straights",
          "type": "array"
        },
        "sectors": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Sector"
          },
          "title": "Sectors",
          "type": "array"
        },
        "pit": {
          "anyOf": [
            {
              "$ref": "#/$defs/Pit"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "marshal_posts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PointRef"
          },
          "title": "Marshal Posts",
          "type": "array"
        },
        "access_points": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PointRef"
          },
          "title": "Access Points",
          "type": "array"
        }
      },
      "required": [
        "id",
        "name",
        "geometry"
      ],
      "title": "Layout",
      "type": "object"
    },
    "Location": {
      "additionalProperties": false,
      "properties": {
        "lat": {
          "title": "Lat",
          "type": "number"
        },
        "lon": {
          "title": "Lon",
          "type": "number"
        },
        "locality": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Locality"
        },
        "region": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region"
        },
        "timezone": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timezone"
        }
      },
      "required": [
        "lat",
        "lon"
      ],
      "title": "Location",
      "type": "object"
    },
    "NameLayer": {
      "additionalProperties": false,
      "description": "Registry entry describing one corner-name layer for clients.",
      "properties": {
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Human-readable layer name for UI.",
          "title": "Label"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "title": "NameLayer",
      "type": "object"
    },
    "Pit": {
      "additionalProperties": false,
      "properties": {
        "entry": {
          "anyOf": [
            {
              "description": "Lap fraction in [0,1].",
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entry"
        },
        "exit": {
          "anyOf": [
            {
              "description": "Lap fraction in [0,1].",
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exit"
        }
      },
      "title": "Pit",
      "type": "object"
    },
    "PointRef": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "location": {
          "description": "[longitude, latitude] in GeoJSON axis order (WGS84).",
          "items": {
            "type": "number"
          },
          "maxItems": 2,
          "minItems": 2,
          "title": "Location",
          "type": "array"
        },
        "marker": {
          "anyOf": [
            {
              "description": "Lap fraction in [0,1].",
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Marker"
        }
      },
      "required": [
        "location"
      ],
      "title": "PointRef",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": true,
      "properties": {
        "generated_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generated At"
        },
        "sources": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sources"
        },
        "corner_match": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Corner Match"
        }
      },
      "title": "Provenance",
      "type": "object"
    },
    "Sector": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "marker": {
          "description": "Lap fraction in [0,1].",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Marker",
          "type": "number"
        }
      },
      "required": [
        "name",
        "marker"
      ],
      "title": "Sector",
      "type": "object"
    },
    "Straight": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "aka": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Aka",
          "type": "array"
        },
        "start": {
          "anyOf": [
            {
              "description": "Lap fraction in [0,1].",
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start"
        },
        "end": {
          "anyOf": [
            {
              "description": "Lap fraction in [0,1].",
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End"
        }
      },
      "required": [
        "name"
      ],
      "title": "Straight",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "slug": {
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "title": "Slug",
      "type": "string"
    },
    "name": {
      "description": "Official circuit name.",
      "title": "Name",
      "type": "string"
    },
    "aka": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Aka",
      "type": "array"
    },
    "country": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "ISO 3166-1 alpha-2 code.",
      "title": "Country"
    },
    "location": {
      "$ref": "#/$defs/Location"
    },
    "wikidata": {
      "anyOf": [
        {
          "pattern": "^Q[0-9]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Wikidata"
    },
    "series": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Series",
      "type": "array"
    },
    "external_ids": {
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "title": "External Ids",
      "type": "object"
    },
    "name_layers": {
      "description": "Registry of corner-name layers. Keys are layer codes; clients enumerate these to offer a layer to display. 'numbered' and 'official' are mandatory; 'driver' is the usual default.",
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "$ref": "#/$defs/NameLayer"
        }
      },
      "title": "Name Layers",
      "type": "object"
    },
    "layouts": {
      "items": {
        "$ref": "#/$defs/Layout"
      },
      "minItems": 1,
      "title": "Layouts",
      "type": "array"
    },
    "provenance": {
      "anyOf": [
        {
          "$ref": "#/$defs/Provenance"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "slug",
    "name",
    "location",
    "name_layers",
    "layouts"
  ],
  "type": "object"
}
