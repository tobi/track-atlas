{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tobi/track-atlas/schema/track.schema.json",
  "title": "Track",
  "description": "Clean, source-agnostic metadata for a single racing circuit (tracks/<slug>/track.json). GENERATED from scripts/lib/models.py — do not edit by hand; run scripts/build_schema.py.",
  "$defs": {
    "Geometry": {
      "additionalProperties": false,
      "properties": {
        "centerline": {
          "description": "Path (relative to track dir) to the layout's GeoJSON centerline/layer file.",
          "title": "Centerline",
          "type": "string"
        },
        "crs": {
          "default": "EPSG:4326",
          "title": "Crs",
          "type": "string"
        }
      },
      "required": [
        "centerline"
      ],
      "title": "Geometry",
      "type": "object"
    },
    "LabelLayer": {
      "additionalProperties": false,
      "description": "Registry entry describing one label/name layer for clients.",
      "properties": {
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Human-readable layer name for UI.",
          "title": "Label"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "title": "LabelLayer",
      "type": "object"
    },
    "Layout": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "aka": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Aka",
          "type": "array"
        },
        "series": {
          "default": [],
          "description": "Series that use THIS layout/configuration.",
          "items": {
            "type": "string"
          },
          "title": "Series",
          "type": "array"
        },
        "length_m": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Lap length in metres.",
          "title": "Length M"
        },
        "direction": {
          "anyOf": [
            {
              "enum": [
                "clockwise",
                "anticlockwise"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direction"
        },
        "active_years": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Free-form, e.g. '2018-' or '1972,1979-1989'.",
          "title": "Active Years"
        },
        "geometry": {
          "$ref": "#/$defs/Geometry"
        },
        "label_default": {
          "default": "driver",
          "description": "Label layer code used as the default display name. Resolution is two steps: item.labels[label_default] if present, else item.labels.numbered.",
          "title": "Label Default",
          "type": "string"
        },
        "point_layers": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PointLayer"
          },
          "title": "Point Layers",
          "type": "array"
        },
        "range_layers": {
          "default": [],
          "items": {
            "$ref": "#/$defs/RangeLayer"
          },
          "title": "Range Layers",
          "type": "array"
        }
      },
      "required": [
        "id",
        "name",
        "geometry"
      ],
      "title": "Layout",
      "type": "object"
    },
    "Location": {
      "additionalProperties": false,
      "properties": {
        "lat": {
          "title": "Lat",
          "type": "number"
        },
        "lon": {
          "title": "Lon",
          "type": "number"
        },
        "locality": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Locality"
        },
        "region": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region"
        },
        "timezone": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timezone"
        }
      },
      "required": [
        "lat",
        "lon"
      ],
      "title": "Location",
      "type": "object"
    },
    "PointItem": {
      "additionalProperties": false,
      "description": "A discrete annotation on a layout lap coordinate.\n\nThe corners layer uses number/code/direction/scale/labels. Layout control\npoints such as start_finish, pit_entry and pit_exit usually use label,\nmarker and location.",
      "properties": {
        "id": {
          "pattern": "^[a-z0-9][a-z0-9_-]*$",
          "title": "Id",
          "type": "string"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "marker": {
          "anyOf": [
            {
              "description": "Lap fraction in [0,1].",
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Marker"
        },
        "location": {
          "anyOf": [
            {
              "description": "[longitude, latitude] in GeoJSON axis order (WGS84).",
              "items": {
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location"
        },
        "location_source": {
          "anyOf": [
            {
              "enum": [
                "osm-way",
                "centerline",
                "manual"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location Source"
        },
        "labels": {
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": {
              "type": "string"
            }
          },
          "title": "Labels",
          "type": "object"
        },
        "number": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Number"
        },
        "code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code"
        },
        "direction": {
          "anyOf": [
            {
              "enum": [
                "left",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direction"
        },
        "scale": {
          "anyOf": [
            {
              "maximum": 6,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Severity 1-6: 1=Hairpin, 2=Slow, 3=Medium, 4=Fast, 5=Very fast, 6=Kink.",
          "title": "Scale"
        }
      },
      "required": [
        "id"
      ],
      "title": "PointItem",
      "type": "object"
    },
    "PointLayer": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Kind",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "series": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Series",
          "type": "array"
        },
        "items": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PointItem"
          },
          "title": "Items",
          "type": "array"
        }
      },
      "required": [
        "id",
        "kind",
        "label"
      ],
      "title": "PointLayer",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": true,
      "properties": {
        "generated_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generated At"
        },
        "sources": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sources"
        },
        "corner_match": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Corner Match"
        }
      },
      "title": "Provenance",
      "type": "object"
    },
    "RangeItem": {
      "additionalProperties": false,
      "description": "A lap interval annotation.",
      "properties": {
        "id": {
          "pattern": "^[a-z0-9][a-z0-9_-]*$",
          "title": "Id",
          "type": "string"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "start": {
          "description": "Lap fraction in [0,1].",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Start",
          "type": "number"
        },
        "end": {
          "description": "Lap fraction in [0,1].",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "End",
          "type": "number"
        },
        "labels": {
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": {
              "type": "string"
            }
          },
          "title": "Labels",
          "type": "object"
        },
        "anchor": {
          "anyOf": [
            {
              "pattern": "^[a-z0-9][a-z0-9_-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Point item this range is derived from, e.g. a corner apex id.",
          "title": "Anchor"
        },
        "members": {
          "default": [],
          "description": "Point items contained in this range, e.g. corners in a complex.",
          "items": {
            "pattern": "^[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "title": "Members",
          "type": "array"
        },
        "entry_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Upstream timing loop / line where the range starts, when known.",
          "title": "Entry Ref"
        },
        "exit_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Upstream timing loop / line where the range ends, when known.",
          "title": "Exit Ref"
        },
        "length_m": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Official/source length of this range in metres, when known.",
          "title": "Length M"
        }
      },
      "required": [
        "id",
        "start",
        "end"
      ],
      "title": "RangeItem",
      "type": "object"
    },
    "RangeLayer": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Kind",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "series": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Series",
          "type": "array"
        },
        "coverage": {
          "anyOf": [
            {
              "enum": [
                "partition",
                "partial",
                "overlap"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Coverage"
        },
        "generated": {
          "default": false,
          "title": "Generated",
          "type": "boolean"
        },
        "provenance": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provenance"
        },
        "items": {
          "default": [],
          "items": {
            "$ref": "#/$defs/RangeItem"
          },
          "title": "Items",
          "type": "array"
        }
      },
      "required": [
        "id",
        "kind",
        "label"
      ],
      "title": "RangeLayer",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "slug": {
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "title": "Slug",
      "type": "string"
    },
    "name": {
      "description": "Official circuit/facility name.",
      "title": "Name",
      "type": "string"
    },
    "aka": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Aka",
      "type": "array"
    },
    "country": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "ISO 3166-1 alpha-2 code.",
      "title": "Country"
    },
    "location": {
      "$ref": "#/$defs/Location"
    },
    "wikidata": {
      "anyOf": [
        {
          "pattern": "^Q[0-9]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Wikidata"
    },
    "series": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Series",
      "type": "array"
    },
    "external_ids": {
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "title": "External Ids",
      "type": "object"
    },
    "label_layers": {
      "description": "Registry of label/name layers. Keys are label codes used by item.labels. 'numbered' and 'official' are mandatory; 'driver' is the usual default.",
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "$ref": "#/$defs/LabelLayer"
        }
      },
      "title": "Label Layers",
      "type": "object"
    },
    "layouts": {
      "items": {
        "$ref": "#/$defs/Layout"
      },
      "minItems": 1,
      "title": "Layouts",
      "type": "array"
    },
    "provenance": {
      "anyOf": [
        {
          "$ref": "#/$defs/Provenance"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "slug",
    "name",
    "location",
    "label_layers",
    "layouts"
  ],
  "type": "object"
}
